// Defining parameters
params {

  // Basic options
  data                                                  = ""
  output                                                = ""
  version                                               = false
  help                                                  = false
  gene_completeness                                     = 50
  upper_coverage_bound                                  = 3
  lower_coverage_bound                                  = 0.5
  normalised_coverage_boundary_plot                     = 10
  tax_id                                                = ""
  outgroup_tax_id                                       = ""
  genomes                                               = 5
  config                                                = ""
  parallel                                              = 10
  trusted_data                                          = false
  test                                                  = false
  n_samples_heatmap                                     = 50
  threshold_value_heatmap                               = 0.8

  // get_data.nf [single core]
  get_data_parallel                                     = 3

  // remove_redundancy.nf	[single core]
  remove_redundancy_parallel                            = 30
  fastANI_threads                                       = 30

	// [cd-hit] gene_clustering.nf
  gene_identity_clustering                              = 0.95
  cd_hit_threads                                        = 30

  // [prokka] [multi core] annotate.nf
  prokka_annotate_parallel                              = 6
  prokka_annotate_threads                               = 5

  // [panaroo] make_pangenome.nf
  pangenome_identity_threshold                          = 0.95
  panaroo_pangenome_mode                                = "strict"
  panaroo_pangenome_threads                             = 30
  panaroo_alignment_type                                = "pan"

  // [bwa , samtools] outgroup_alignment.nf
  outgroup_alignment_threads                            = 30
	
  // [bwa, samtools, mapdamage] [multi core] alignment.nf
  alignment_threads                                     = 10
  missing_prob                                          = 0.01
  gap_fraction                                          = 2
  seed                                                  = 16500
  min_read_length                                       = 34
  mapping_quality                                       = 30
  max_read_length                                       = 300
  alignment_parallel                                    = 3
  rescale                                               = 1

  // update_normalization.nf [single core]
  update_normalization_parallel                         = 30

  // extend_sequences.nf [single core]
  bedtools_slop                                         = 20
  extend_sequences_parallel                             = 30

  // mapdamage.nf [single core]
  mapdamage_parallel                                    = 30

  // realign.nf [multi core]
  realign_parallel                                      = 6
  mafft_threads                                         = 5

  // [bcftools] genotyping.nf
  bcftools_map_quality                                  = 30
  bcftools_base_quality                                 = 30
  variant_call_quality                                  = 10
  force_homozygosity									= 0 

  // filter_gene_alignments.nf [single core]
  filter_gene_alignments_parallel                       = 30

  // [iq-tree] tree_{}.nf 
  // WARNING: there will be 4 iq-tree runs in parallel
  skip_trees											= false
  tree_threads                                          = 10
}	


// Make scripts usable
process {
    beforeScript = "chmod ugo+rwx ${projectDir}/bin/* ${projectDir}/test/*"
}

// Defining standard resources

process {
  withLabel: demand_1 {
    cpus = 1
    memory = '10 GB'
  }
}

process {
  withLabel: demand_2 {
    cpus = 2
    memory = '10 GB'
  }
}

process {
  withLabel: demand_3 {
    cpus = 5
    memory = '50 GB'
  }
}

process {
  withLabel: demand_4 {
    cpus = 10
    memory = '100 GB'
  }
}

process {
  withLabel: demand_5 {
    cpus = 20
    memory = '200 GB'
  }
}

// Defining specific configs

conda.enabled = true
conda.useMamba = false
